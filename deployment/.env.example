# P2P Mesh Network — Environment Variables (Development)
# WARNING: These are DEV defaults. Change ALL values before production use.

# PostgreSQL
POSTGRES_PASSWORD=mesh_dev_password_change_me

# Redis
REDIS_PASSWORD=redis_dev_password_change_me

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(64))")
JWT_SECRET=dev-jwt-secret-change-me-in-production-use-secrets-token-hex-64

# Relay authentication token (shared secret between API and relay nodes)
RELAY_AUTH_TOKEN=dev-relay-auth-token-change-me-in-production

# Internal API key (shared secret for inter-service authentication)
# All microservices use this to authenticate requests from other services.
INTERNAL_API_KEY=dev-internal-api-key-change-me-in-production

# Relay node ID
RELAY_ID=relay-primary

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_dev_password_change_me
