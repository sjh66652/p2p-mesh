# P2P Mesh Network — Environment Variables v2.0.0
# Copy to: system environment or .env file

# === Client (mesh-tunnel) ===
MESH_TOKEN=your_jwt_token_here
MESH_DEVICE_ID=
MESH_API_URL=https://your-mesh-server.example.com

# === Relay Server (mesh-relay) ===
RELAY_AUTH_TOKEN=your_relay_auth_token_here
RELAY_ID=relay-us-east-1
REGION=us-east
RELAY_PORT=51821
RELAY_MAX_CONNECTIONS=1000
RELAY_BANDWIDTH_MBPS=1000
HEARTBEAT_INTERVAL=30

# === Overlay Node (mesh-overlay) ===
MESH_AUTH_TOKEN=

# === Security ===
# Hole punching HMAC key — 64 hex chars. Generate: openssl rand -hex 32
PUNCH_HMAC_KEY=

# === API ===
API_URL=https://your-mesh-server.example.com
