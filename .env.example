# P2P Mesh Network - Environment Configuration
# Copy this file to .env and fill in ALL values marked CHANGE_ME.

# Database
DATABASE_URL=postgresql+asyncpg://mesh:CHANGE_ME_DB_PASSWORD@postgres:5432/p2p_mesh
DATABASE_URL_SYNC=postgresql://mesh:CHANGE_ME_DB_PASSWORD@postgres:5432/p2p_mesh

# Redis (use strong password in production: openssl rand -hex 16)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# NAT / STUN
STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302

# Internal API key for service-to-service authentication (openssl rand -hex 32)
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# Relay
RELAY_CLEANUP_INTERVAL=300
RELAY_MAX_LOAD=0.8

# Billing
FREE_PLAN_BANDWIDTH_MBPS=1
PRO_PLAN_BANDWIDTH_MBPS=0
ENTERPRISE_PLAN_BANDWIDTH_MBPS=0

# Security
RATE_LIMIT_PER_MINUTE=60
TLS_ENABLED=false

# Monitoring
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
