# P2P Mesh Network - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://mesh:mesh_pass@postgres:5432/p2p_mesh
DATABASE_URL_SYNC=postgresql://mesh:mesh_pass@postgres:5432/p2p_mesh

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# NAT / STUN
STUN_SERVERS=stun.l.google.com:19302,stun1.l.google.com:19302

# Internal API key for service-to-service authentication
INTERNAL_API_KEY=change-this-internal-api-key

# Relay
RELAY_CLEANUP_INTERVAL=300
RELAY_MAX_LOAD=0.8

# Billing
FREE_PLAN_BANDWIDTH_MBPS=1
PRO_PLAN_BANDWIDTH_MBPS=0
ENTERPRISE_PLAN_BANDWIDTH_MBPS=0

# Security
RATE_LIMIT_PER_MINUTE=60
TLS_ENABLED=false

# Monitoring
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
