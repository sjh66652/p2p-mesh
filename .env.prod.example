# P2P Mesh Network - Production Environment Variables
# 复制为 .env.prod 并填入真实值

# Docker 镜像
DOCKER_REGISTRY=docker.io/yourorg
IMAGE_TAG=latest

# JWT 密钥（openssl rand -hex 32）
JWT_SECRET=change-me-to-random-hex-64-chars

# 数据库密码（openssl rand -base64 32）
POSTGRES_PASSWORD=change-me-to-random

# Redis 密码（openssl rand -hex 16）
REDIS_PASSWORD=change-me-to-random

# Relay 节点
RELAY_ID=relay-primary
RELAY_REGION=us-east-1

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-to-strong-password

# 日志
LOG_LEVEL=INFO

# 限流
RATE_LIMIT=120
