# P2P Mesh Network - Usage Service Environment Variables
# Copy to .env and replace ALL CHANGE_ME values before production use.

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://mesh:CHANGE_ME_DB_PASSWORD@postgres:5432/p2p_mesh

# Redis connection string (with password if set)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# JWT secret (must match other services, generate: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_JWT_SECRET

# Internal API key for service-to-service authentication
# Must match INTERNAL_API_KEY in other services (generate: openssl rand -hex 32)
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Plan limits (overridable per environment)
FREE_MAX_REQUESTS_PER_MIN=100
FREE_MAX_CONNECTIONS=3
FREE_MAX_BANDWIDTH_PER_DAY_GB=1

PRO_MAX_REQUESTS_PER_MIN=1000
PRO_MAX_CONNECTIONS=10
PRO_MAX_BANDWIDTH_PER_DAY_GB=50

ENTERPRISE_MAX_REQUESTS_PER_MIN=10000
ENTERPRISE_MAX_CONNECTIONS=50
ENTERPRISE_MAX_BANDWIDTH_PER_DAY_GB=500

# Abuse prevention
ABUSE_BAN_DURATION_HOURS=24

# Monitoring
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
